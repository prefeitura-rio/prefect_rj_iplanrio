# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# NUNCA suba o .env.local para o git.

# ---------------------------------------------------------------------------
# Bulk API 2.0 (objetos CRM padrão — BotSession, MessagingSession etc.)
# Flow: OAuth2 Username-Password
# ---------------------------------------------------------------------------
SF_CRM_CLIENT_ID=seu_client_id_aqui
SF_CRM_CLIENT_SECRET=seu_client_secret_aqui
SF_CRM_USERNAME=seu_usuario@exemplo.com
SF_CRM_PASSWORD=suaSenha+SecurityToken
SF_CRM_LOGIN_URL=https://login.salesforce.com
# Para sandbox, use: SF_CRM_LOGIN_URL=https://test.salesforce.com

# ---------------------------------------------------------------------------
# Data Cloud Query API (DMOs do Agentforce — AiAgentSession etc.)
# Flow: OAuth2 Client Credentials (sem senha)
# Connected App: DataCloud_Integration
# ---------------------------------------------------------------------------
SF_DC_CLIENT_ID=seu_consumer_key_aqui
SF_DC_CLIENT_SECRET=seu_consumer_secret_aqui
SF_DC_INSTANCE_URL=https://prefeitura-rio.my.salesforce.com
SF_DC_DATASPACE=default
# Para QA, troque SF_DC_CLIENT_ID e SF_DC_CLIENT_SECRET pelas credenciais QA
