# BigQuery Configuration
PIC_DISPAROS_EMAIL_BIGQUERY_PROJECT_ID=your-project-id
PIC_DISPAROS_EMAIL_BIGQUERY_DATASET_ID=your-dataset-id
PIC_DISPAROS_EMAIL_BIGQUERY_TABLE_ID=your-table-id

# Data Relay API Configuration
PIC_DISPAROS_EMAIL_DATA_RELAY_URL=https://data-relay.dados.rio/data/mailman
PIC_DISPAROS_EMAIL_DATA_RELAY_API_KEY=your-api-key-here
PIC_DISPAROS_EMAIL_DATA_RELAY_FROM_ADDRESS=noreply@example.com
PIC_DISPAROS_EMAIL_DATA_RELAY_USE_GMAIL_API=false
PIC_DISPAROS_EMAIL_DATA_RELAY_IS_HTML_BODY=true

# Retry and Throttle Settings
PIC_DISPAROS_EMAIL_MAX_RETRIES=3
PIC_DISPAROS_EMAIL_RETRY_DELAY=5
PIC_DISPAROS_EMAIL_THROTTLE_DELAY=1
